types = {
    ## type_key_filter = townrights_manager
    type[townrights_manager] = {
        path = "game/setup/start"
        path = "game/in_game/setup/start"
        path = "game/main_menu/setup/start"
        path = "game/loading_screen/setup/start"
        path_extension = .txt
        unique = no
    }
}

townrights_manager = {
    ## cardinality = 0..inf
    value[location] = <town_right>
}

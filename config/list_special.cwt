# = Exceptions

### Iterate through all countries in the international organization which have the specified special status
## scopes = { international_organization }
## push_scope = country
alias[effect:every_country_with_special_status_of_type] = {
    type = <international_organization_special_status>

    ## cardinality = 0..1
    limit = single_alias_right[trigger_clause]

    ## cardinality = 0..inf
    alternative_limit = single_alias_right[trigger_clause]

    alias_name[effect] = alias_match_left[effect]
}
### Iterate through all countries in the international organization which have the specified special status
## scopes = { international_organization }
## push_scope = country
alias[effect:random_country_with_special_status_of_type] = {
    type = <international_organization_special_status>

    ## cardinality = 0..1
    limit = single_alias_right[trigger_clause]

    ## cardinality = 0..inf
    alternative_limit = single_alias_right[trigger_clause]

    ## cardinality = 0..1
    weight = single_alias_right[formula]

    alias_name[effect] = alias_match_left[effect]
}
### Iterate through all countries in the international organization which have the specified special status
## scopes = { international_organization }
## push_scope = country
alias[effect:ordered_country_with_special_status_of_type] = {
    type = <international_organization_special_status>

    ## cardinality = 0..1
    limit = single_alias_right[trigger_clause]

    ## cardinality = 0..inf
    alternative_limit = single_alias_right[trigger_clause]

    ## cardinality = 0..1
    order_by = value_field
    ## cardinality = 0..1
    order_by = single_alias_right[formula]
    ## cardinality = 0..1
    order_by = $define_reference

    ## cardinality = 0..1
    min = int_value_field
    ## cardinality = 0..1
    min = single_alias_right[formula]
    ## cardinality = 0..1
    min = $define_reference

    ## cardinality = 0..1
    max = int_value_field
    ## cardinality = 0..1
    max = single_alias_right[formula]
    ## cardinality = 0..1
    max = $define_reference

    ## cardinality = 0..1
    position = int

    ## cardinality = 0..1
    check_range_bounds = no

    alias_name[effect] = alias_match_left[effect]
}

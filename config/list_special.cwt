### Iterate through all countries in the international organization which have the specified special status
## scopes = { international_organization }
## push_scope = country
alias[trigger:any_country_with_special_status_of_type] = {
    type = <international_organization_special_status>

    ## cardinality = 0..1
    percent = value_field[0.0..1.0]
    ## cardinality = 0..1
    percent = single_alias_right[formula]
    ## cardinality = 0..1
    percent = $define_reference

    ## cardinality = 0..1
    count = int_value_field
    ## cardinality = 0..1
    count = single_alias_right[formula]
    ## cardinality = 0..1
    count = $define_reference
    ## cardinality = 0..1
    count = all

    ## cardinality = 0..1
    ### If set, count = all and percent only consider the filtered items for the denominator.
    filter = single_alias_right[trigger_clause]

    alias_name[trigger] = alias_match_left[trigger]
}


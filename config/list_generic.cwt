# = Effect List Clauses
single_alias[effect_every_list_clause] = {
    ## cardinality = 0..1
    custom = localisation

    ## cardinality = 0..1
    limit = single_alias_right[trigger_clause]

    ## cardinality = 0..inf
    alternative_limit = single_alias_right[trigger_clause]

    alias_name[effect] = alias_match_left[effect]
}
single_alias[effect_random_list_clause] = {
    ## cardinality = 0..1
    custom = localisation

    ## cardinality = 0..1
    limit = single_alias_right[trigger_clause]

    ## cardinality = 0..inf
    alternative_limit = single_alias_right[trigger_clause]

    ## cardinality = 0..1
    weight = single_alias_right[formula]

    alias_name[effect] = alias_match_left[effect]
}
single_alias[effect_ordered_list_clause] = {
    ## cardinality = 0..1
    custom = localisation

    ## cardinality = 0..1
    limit = single_alias_right[trigger_clause]

    ## cardinality = 0..inf
    alternative_limit = single_alias_right[trigger_clause]

    ## cardinality = 0..inf
    order_by = value_field
    ## cardinality = 0..inf
    order_by = single_alias_right[formula]
    ## cardinality = 0..inf
    order_by = $define_reference

    ## cardinality = 0..1
    min = int_value_field
    ## cardinality = 0..1
    min = single_alias_right[formula]
    ## cardinality = 0..1
    min = $define_reference

    ## cardinality = 0..1
    max = int_value_field
    ## cardinality = 0..1
    max = single_alias_right[formula]
    ## cardinality = 0..1
    max = $define_reference

    ## cardinality = 0..1
    position = int

    ## cardinality = 0..1
    check_range_bounds = no

    alias_name[effect] = alias_match_left[effect]
}

# = Formula List Clauses
single_alias[formula_every_list_clause] = {
    ## cardinality = 0..1
    custom = localisation

    ## cardinality = 0..1
    limit = single_alias_right[trigger_clause]

    ## cardinality = 0..inf
    alternative_limit = single_alias_right[trigger_clause]

    alias_name[arithmetic_operation] = alias_match_left[arithmetic_operation]
}
single_alias[formula_ordered_list_clause] = {
    ## cardinality = 0..1
    custom = localisation

    ## cardinality = 0..1
    limit = single_alias_right[trigger_clause]

    ## cardinality = 0..inf
    alternative_limit = single_alias_right[trigger_clause]

    ## cardinality = 0..inf
    order_by = value_field
    ## cardinality = 0..inf
    order_by = single_alias_right[formula]
    ## cardinality = 0..inf
    order_by = $define_reference

    ## cardinality = 0..1
    min = int_value_field
    ## cardinality = 0..1
    min = single_alias_right[formula]
    ## cardinality = 0..1
    min = $define_reference

    ## cardinality = 0..1
    max = int_value_field
    ## cardinality = 0..1
    max = single_alias_right[formula]
    ## cardinality = 0..1
    max = $define_reference

    ## cardinality = 0..1
    position = int

    ## cardinality = 0..1
    check_range_bounds = no

    alias_name[arithmetic_operation] = alias_match_left[arithmetic_operation]
}
single_alias[formula_random_list_clause] = {
    ## cardinality = 0..1
    custom = localisation

    ## cardinality = 0..1
    limit = single_alias_right[trigger_clause]

    ## cardinality = 0..inf
    alternative_limit = single_alias_right[trigger_clause]

    ## cardinality = 0..1
    weight = single_alias_right[formula]

    alias_name[arithmetic_operation] = alias_match_left[arithmetic_operation]
}

# = Trigger List Clauses
single_alias[trigger_any_list_clause] = {
    ## cardinality = 0..1
    custom = localisation

    ## cardinality = 0..1
    percent = value_field[0.0..1.0]
    ## cardinality = 0..1
    percent = single_alias_right[formula]
    ## cardinality = 0..1
    percent = $define_reference

    ## cardinality = 0..1
    count == int_value_field
    ## cardinality = 0..1
    count == single_alias_right[formula]
    ## cardinality = 0..1
    count == $define_reference
    ## cardinality = 0..1
    count == all

    ## cardinality = 0..1
    ### If set, count = all and percent only consider the filtered items for the denominator.
    filter = single_alias_right[trigger_clause]

    alias_name[trigger] = alias_match_left[trigger]
}

# = Lists

## scopes = { any }
## push_scope = any
alias[effect:every_<scripted_list>] = single_alias_right[effect_every_list_clause]
## scopes = { any }
## push_scope = any
alias[effect:random_<scripted_list>] = single_alias_right[effect_random_list_clause]
## scopes = { any }
## push_scope = any
alias[effect:ordered_<scripted_list>] = single_alias_right[effect_ordered_list_clause]
## scopes = { any }
## push_scope = any
alias[arithmetic_operation:every_<scripted_list>] = single_alias_right[formula_every_list_clause]
## scopes = { any }
## push_scope = any
alias[arithmetic_operation:random_<scripted_list>] = single_alias_right[formula_random_list_clause]
## scopes = { any }
## push_scope = any
alias[arithmetic_operation:ordered_<scripted_list>] = single_alias_right[formula_ordered_list_clause]
## scopes = { any }
## push_scope = any
alias[trigger:any_<scripted_list>] = single_alias_right[trigger_any_list_clause]

